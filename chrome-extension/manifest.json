{
  "manifest_version": 3,
  "name": "Tailrd — Job Application Autofill",
  "version": "0.3.0",
  "description": "Detects job application forms (Greenhouse, Lever, Workday, Ashby, BambooHR, SmartRecruiters, iCIMS, Jobvite, Taleo, SuccessFactors and more) and fills them from your Tailrd profile. Never submits anything automatically.",
  "minimum_chrome_version": "110",
  "key": "",
  "icons": {
    "16": "assets/icon-16.png",
    "32": "assets/icon-32.png",
    "48": "assets/icon-48.png",
    "128": "assets/icon-128.png"
  },
  "action": {
    "default_title": "Tailrd Autofill",
    "default_icon": {
      "16": "assets/icon-16.png",
      "32": "assets/icon-32.png",
      "48": "assets/icon-48.png",
      "128": "assets/icon-128.png"
    }
  },
  "background": {
    "service_worker": "serviceWorker.js"
  },
  "permissions": ["activeTab", "storage", "scripting", "identity", "alarms"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "https://www.google.com/recaptcha/*",
        "https://recaptcha.net/*",
        "https://www.recaptcha.net/*",
        "https://*.hcaptcha.com/*",
        "https://challenges.cloudflare.com/*"
      ],
      "js": ["contentScript.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    { "resources": ["mainWorld.js"], "matches": ["<all_urls>"] }
  ]
}
