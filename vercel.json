{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/github-sources/cron-poll",
      "schedule": "0 * * * *"
    },
    {
      "path": "/github-sources/cron-ats",
      "schedule": "0 */6 * * *"
    }
  ],
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/dist",
  "framework": null,
  "functions": {
    "api/**/*.py": {
      "excludeFiles": "{backend/tests/**,**/test_*.py,**/*.test.py,**/__pycache__/**,**/.pytest_cache/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/health",
      "destination": "/api/index.py"
    },
    {
      "source": "/resumes",
      "destination": "/api/index.py"
    },
    {
      "source": "/resumes/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/ai/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/jobs/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/jobs",
      "destination": "/api/index.py"
    },
    {
      "source": "/settings/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/settings",
      "destination": "/api/index.py"
    },
    {
      "source": "/connections/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/apply/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/github-sources(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/auth/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/auth",
      "destination": "/api/index.py"
    },
    {
      "source": "/((?!assets/).*)",
      "destination": "/index.html"
    }
  ]
}
