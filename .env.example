# === LLM Provider (gemini or ollama) ===
LLM_PROVIDER=gemini

# === Gemini (cloud) ===
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# === Ollama (local fallback) ===
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3
OLLAMA_TIMEOUT=120

# === Database ===
DATABASE_URL=sqlite:///./data/autoapply.db

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === LinkedIn Credentials (NEVER commit real values) ===
LINKEDIN_EMAIL=your-email@example.com
LINKEDIN_PASSWORD=your-password-here

# === Bot Settings ===
BOT_JOB_TITLE=Software Engineer
BOT_LOCATION=United States
BOT_REMOTE_FILTER=2
BOT_MIN_DELAY=2
BOT_MAX_DELAY=5
MAX_APPLICATIONS_PER_RUN=25
BOT_HEADLESS=true
RESUME_FILE_PATH=/app/data/resume.pdf

# === User Profile (for form filling) ===
USER_FIRST_NAME=John
USER_LAST_NAME=Doe
USER_EMAIL=john@example.com
USER_PHONE=555-0100
USER_CITY=San Francisco
USER_LINKEDIN_URL=https://linkedin.com/in/johndoe
USER_WEBSITE=https://johndoe.dev

# === CORS ===
CORS_ORIGINS=http://localhost:5173

# === GitHub (for job aggregator — optional but recommended to avoid rate limits) ===
GITHUB_TOKEN=your-github-personal-access-token

# === GEMENI ===
GEMINI_API_KEY=AIzaSyAfKudWOxaC72iPb_qc-A-LJR2fiATpMeg