# === Gemini API ===
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# === Database (Neon PostgreSQL) ===
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-YOUR-ENDPOINT.us-east-1.aws.neon.tech/neondb?sslmode=require

# === User Profile (for form filling) ===
USER_FIRST_NAME=John
USER_LAST_NAME=Doe
USER_EMAIL=john@example.com
USER_PHONE=555-0100
USER_CITY=San Francisco
USER_LINKEDIN_URL=https://linkedin.com/in/johndoe
USER_WEBSITE=https://johndoe.dev

# === CORS ===
CORS_ORIGINS=http://localhost:5173

# === GitHub (for job aggregator — optional but recommended to avoid rate limits) ===
GITHUB_TOKEN=your-github-personal-access-token
